@Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })
@model EAPD7111_Part2.Models.ServiceRequest
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-center text-primary mb-4">Create Service Request</h2>

<div class="d-flex justify-content-center">
    <div class="card shadow-sm p-4" style="width: 50%;">
        <!-- ✅ Show validation errors -->
        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

        <form asp-action="Create" method="post">
            <!-- Hidden ContractId ensures request is linked -->
            <input type="hidden" asp-for="ContractId" />

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CostUSD" class="form-label">Cost (USD)</label>
                <input asp-for="CostUSD" class="form-control" />
                <span asp-validation-for="CostUSD" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <input asp-for="Status" class="form-control" />
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-primary">Save Request</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
