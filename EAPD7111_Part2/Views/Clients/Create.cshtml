@Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })
@model EAPD7111_Part2.Models.Client
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-center text-primary mb-4">Create Client</h2>

<div class="d-flex justify-content-center">
    <div class="card shadow-sm p-4" style="width: 50%;">
        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ContactDetails" class="form-label"></label>
                <input asp-for="ContactDetails" class="form-control" />
                <span asp-validation-for="ContactDetails" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Region" class="form-label"></label>
                <input asp-for="Region" class="form-control" />
                <span asp-validation-for="Region" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
