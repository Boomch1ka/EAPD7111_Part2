@model EAPD7111_Part2.Models.Contract
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Upload Agreement</h2>
<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label asp-for="ClientId">Client</label>
        <input asp-for="ClientId" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Status"></label>
        <input asp-for="Status" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="ServiceLevel"></label>
        <input asp-for="ServiceLevel" class="form-control" />
    </div>
    <div class="form-group">
        <label>Signed Agreement (PDF)</label>
        <input type="file" name="signedAgreement" class="form-control" />
    </div>
    <button type="submit" class="btn btn-success">Save Contract</button>
</form>
