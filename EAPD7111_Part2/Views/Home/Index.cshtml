@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="text-center mt-5">
    <h1 class="display-3 text-primary fw-bold">Welcome to EventEase 🎉</h1>
    <p class="lead mt-4 mb-5">
        EventEase is your trusted platform for managing <strong>Clients</strong>, <strong>Contracts</strong>,
        and <strong>Service Requests</strong>.
        Whether you're organizing events, tracking agreements, or handling service workflows, everything you need is right here.
        Start exploring by choosing one of the options below — your journey begins now!
    </p>

    <div class="d-flex justify-content-center gap-4 mt-4">
        <a asp-controller="ClientC" asp-action="Index" class="btn btn-primary btn-lg px-5 py-3 shadow-lg">
            Manage Clients
        </a>
        <a asp-controller="ContractC" asp-action="Index" class="btn btn-success btn-lg px-5 py-3 shadow-lg">
            View Contracts
        </a>
        <a asp-controller="ServiceRequestsC" asp-action="Index" class="btn btn-info btn-lg px-5 py-3 shadow-lg">
            Service Requests
        </a>
    </div>
</div>
